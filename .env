# ═══════════════════════════════════════════════════════════════
# BAAGICHA — MOBILE APP ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════
#
# This file is read by react-native-config at build time.
# After editing, rebuild the app:
#   Android: cd android && ./gradlew assembleDebug
#   iOS:     cd ios && pod install && cd .. && npx react-native run-ios
#
# For values with special characters, wrap in double quotes.

# ── API ──
API_BASE_URL=http://192.168.1.100:8000/api/v1

# ── Google Sign-In ──
# Web Client ID from Google Cloud Console (OAuth 2.0 → Web application)
GOOGLE_WEB_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID.apps.googleusercontent.com

# ── Facebook Login ──
# App ID from Facebook Developer Console
FACEBOOK_APP_ID=YOUR_FACEBOOK_APP_ID
# Client Token from Facebook Developer Console → Settings → Advanced
FACEBOOK_CLIENT_TOKEN=YOUR_FACEBOOK_CLIENT_TOKEN
